{
	"name": "frontend",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"start:dev": "vite dev",
		"build": "svelte-kit sync && bun --bun vite build",
		"start:prod": "bun ./build/index.js",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:infra": "bun test src/lib/server",
		"api:schema:pull": "bun ./scripts/pull-openapi.ts",
		"api:generate": "orval --config ./orval.config.ts",
		"api:refresh": "bun run api:schema:pull && bun run api:generate",
		"api:check": "bun run api:generate && git diff --exit-code -- openapi/backend.json src/lib/server/backend/generated"
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"devDependencies": {
		"@eslym/sveltekit-adapter-bun": "^2.1.3",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tailwindcss/typography": "^0.5.14",
		"@types/bun": "^1.3.14",
		"@types/eslint": "^9.6.0",
		"autoprefixer": "^10.4.20",
		"bits-ui": "^0.22.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"globals": "^15.0.0",
		"lucide-svelte": "^0.475.0",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.9",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.0.3"
	},
	"type": "module",
	"dependencies": {
		"@elysiajs/eden": "^1.4.9",
		"@types/jsonwebtoken": "^9.0.8",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"elysia": "^1.4.29",
		"isomorphic-dompurify": "^2.22.0",
		"jsonwebtoken": "^9.0.2",
		"marked": "^15.0.12",
		"tailwind-merge": "^2.5.2",
		"tailwind-variants": "^0.2.1"
	}
}
